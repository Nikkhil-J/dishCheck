{
  "name": "dishcheck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude src/__tests__/rules/",
    "test:rules": "vitest run src/__tests__/rules/",
    "seed": "npx tsx scripts/seed-cities.ts",
    "ingest": "npx tsx scripts/ingest-google-places.ts",
    "emulator": "firebase emulators:start --only firestore",
    "test:e2e": "dotenv -e .env.e2e -- playwright test",
    "test:e2e:ui": "dotenv -e .env.e2e -- playwright test --ui",
    "test:e2e:debug": "dotenv -e .env.e2e -- playwright test --debug"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@next/swc-darwin-arm64": "^16.2.1",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-query": "^5.95.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-cloudinary": "^6.17.5",
    "next-nprogress-bar": "^2.4.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typesense": "^3.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
